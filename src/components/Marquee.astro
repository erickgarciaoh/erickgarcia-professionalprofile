---
interface Props {
	items: string[];
	/** Total groups rendered in the track (1 real + repeat-1 aria-hidden
	 * duplicates). With only a handful of short items, two groups can render
	 * narrower than an ultra-wide viewport — the track runs out of content
	 * and shows blank space before the loop wraps. More copies keep the
	 * -translateX loop seamless at any width; the shift fraction below is
	 * derived from this count, so it stays correct regardless of the value. */
	repeat?: number;
}

const { items, repeat = 8 } = Astro.props;
const shiftPercent = (100 / repeat).toFixed(4);
---

<div class="marquee">
	<div class="marquee-track" style={`--marquee-shift: ${shiftPercent}%`}>
		{
			Array.from({ length: repeat }).map((_, i) => (
				<div class="marquee-group" aria-hidden={i === 0 ? undefined : 'true'}>
					{
						items.map((item) => (
							<>
								<span class="marquee-item">{item}</span>
								<span class="marquee-sep" aria-hidden="true">
									·
								</span>
							</>
						))
					}
				</div>
			))
		}
	</div>
</div>

<style>
	/* Cheapest component on the page by design: pure CSS, no JS (P1-07). The
	   track repeats its content `repeat` times (all groups identical width) so
	   shifting by exactly one group's width (100/repeat%, --marquee-shift)
	   loops seamlessly regardless of group count — the count itself only
	   exists to keep the total track wider than any real viewport (Erick,
	   2026-07-10: with few short items, 2 copies ran narrower than the
	   viewport, so the track visibly ran out before the loop wrapped). */
	.marquee {
		overflow: hidden;
	}

	.marquee-track {
		display: flex;
		width: max-content;
		animation: marquee-scroll 35s linear infinite;
	}

	.marquee:hover .marquee-track,
	.marquee:focus-within .marquee-track {
		animation-play-state: paused;
	}

	.marquee-group {
		display: flex;
		align-items: baseline;
		flex-shrink: 0;
		gap: var(--space-6);
	}

	.marquee-item {
		font-family: var(--font-mono);
		font-size: 0.9375rem;
		letter-spacing: 0.02em;
		color: var(--canvas-500);
		white-space: nowrap;
	}

	@media (hover: hover) and (pointer: fine) {
		.marquee-item {
			transition: color var(--motion-base);
		}

		.marquee-item:hover {
			color: var(--text-primary);
		}
	}

	.marquee-sep {
		color: var(--canvas-600);
		font-size: 0.9375rem;
	}

	@keyframes marquee-scroll {
		to {
			transform: translateX(calc(-1 * var(--marquee-shift, 50%)));
		}
	}

	@media (prefers-reduced-motion: reduce) {
		/* Static wrapped grid of the real items — every aria-hidden duplicate
		   group is hidden below, regardless of how many were rendered. */
		.marquee {
			overflow: visible;
		}

		.marquee-track {
			width: auto;
			animation: none;
			transform: none;
		}

		.marquee-group {
			flex-wrap: wrap;
			flex-shrink: 1;
		}

		.marquee-group[aria-hidden='true'] {
			display: none;
		}
	}
</style>
