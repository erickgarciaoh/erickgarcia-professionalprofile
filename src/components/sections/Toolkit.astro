---
import Marquee from '../Marquee.astro';

const items = ['SQL', 'Power BI', 'DAX', 'Python', 'HTML', 'Claude AI', 'MCP Servers', 'AI Agents'];
---

<section id="toolkit" data-theme="dark" data-section-label="Toolkit" aria-labelledby="toolkit-heading">
	<div class="wrap">
		<h2 id="toolkit-heading" class="section-heading">Toolkit</h2>
		<div class="toolkit-marquee">
			<Marquee items={items} />
		</div>
		<p class="toolkit-note">Currently extending into R and Tableau.</p>
	</div>
</section>

<style>
	/* No top padding / border: this band is the tail of the Metrics dark
	   window (§2.7), not a second adjacent one — one dark world, not two. */
	section#toolkit {
		background: var(--ink-950);
		color: var(--text-primary);
		padding-top: 0;
	}

	.toolkit-marquee {
		margin-top: clamp(var(--space-6), 3vw, var(--space-8));
	}

	.toolkit-note {
		margin-top: var(--space-6);
		font-family: var(--font-mono);
		font-size: 0.875rem;
		color: var(--canvas-500);
	}
</style>

<script>
	// Off-screen pause (P3-06): don't burn compositor time animating a loop
	// nobody sees. Clearing the inline override (rather than forcing 'running')
	// lets the existing hover/focus-within pause rule keep working normally.
	const track = document.querySelector<HTMLElement>('.marquee-track');

	if (track && 'IntersectionObserver' in window) {
		const io = new IntersectionObserver(
			([entry]) => {
				track.style.animationPlayState = entry.isIntersecting ? '' : 'paused';
			},
			{ threshold: 0 },
		);
		io.observe(track);
	}
</script>
