---
import PipelineSteps from '../PipelineSteps.astro';
---

{/* Statement — the ONE star moment (§2.4). Phase 1: the thesis sentence + the four
	PipelineSteps scenes in their FINAL static state. Kinetic typography and the
	per-step timelines arrive in P4-01 / P4-02; here everything reads without JS. */}
<section id="statement" data-section-label="Statement" aria-labelledby="statement-heading">
	<div class="wrap">
		<h2 id="statement-heading" class="sr-only">Statement</h2>
		<p class="statement-sentence" aria-hidden="true">
			I transform complex datasets and databases into{' '}
			<span class="accent-words">understandable visuals</span> for decision-making.
		</p>
		<p class="sr-only">
			I transform complex datasets and databases into understandable visuals for decision-making.
		</p>

		<PipelineSteps />
	</div>
</section>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
		clip-path: inset(50%);
		white-space: nowrap;
		border: 0;
	}

	.statement-sentence {
		max-width: 18ch;
		font-family: var(--font-display);
		font-weight: 600;
		/* Cormorant display, ≥28px floor, ≤6rem ceiling (brand + §2.4). */
		font-size: clamp(1.9rem, 6vw, 5rem);
		line-height: 1.08;
		letter-spacing: -0.015em;
		color: var(--text-primary);
		text-wrap: balance;
	}

	/* This viewport's single amber focus — always amber in this static phase; the
	   progressive scrub-reveal lands in P4-01. */
	.accent-words {
		color: var(--accent);
	}
</style>
