---
import {
	RELIEF_REF_WIDTH,
	RELIEF_REF_HEIGHT,
	buildRestingSvgPaths,
} from '../../scripts/motion/hero-relief-data';

// Static fallback for the hero signature asset (P2-03, blueprint §2.2.2):
// the same resting figure the canvas draws on its first frame (t=0, no
// pointer), contoured at build time by the shared field code — so no-JS /
// reduced-motion / touch / <60rem visitors see the identical "density
// relief" identity.
const reliefPaths = buildRestingSvgPaths();
const levelAlpha = (index: number, role: string) =>
	(role === 'peak' ? 0.85 : Math.min(0.38 + index * 0.06, 0.8)).toFixed(2);
---

<section id="hero" data-section-label="Home" aria-labelledby="hero-heading">
	<div class="wrap hero">
		<div class="hero-content">
			<h1 id="hero-heading" class="hero-heading">Erick García</h1>
			<p class="hero-role">Senior Data Analyst / BI</p>
			<p class="hero-sentence">
				Data analysis, report building and process automation for your specific needs —
				adaptable to different systems and structures, delivering reliable results in the
				shortest possible time.
			</p>
			<div class="hero-actions">
				<a href="#projects" class="btn btn-solid">View the work</a>
				<a href="#contact" class="btn btn-ghost">Get in touch</a>
			</div>
		</div>

		<div class="hero-relief" aria-hidden="true">
			<canvas class="hero-relief-canvas" data-hero-relief></canvas>
			<svg
				class="hero-relief-fallback"
				viewBox={`0 0 ${RELIEF_REF_WIDTH} ${RELIEF_REF_HEIGHT}`}
				preserveAspectRatio="xMidYMid meet"
				focusable="false"
			>
				{
					reliefPaths.map((p, i) => (
						<path
							class={`lv-${p.role}`}
							d={p.d}
							stroke-opacity={levelAlpha(i, p.role)}
						/>
					))
				}
			</svg>
		</div>

		<dl class="masthead" aria-label="At a glance">
			<div class="masthead-row">
				<dt>Focus</dt>
				<dd>SQL Server · Power BI · DAX</dd>
			</div>
			<div class="masthead-row">
				<dt>Currently</dt>
				<dd>Python · Claude API · AI-augmented analytics</dd>
			</div>
			<div class="masthead-row">
				<dt>Based</dt>
				<dd>Colombia · remote / global</dd>
			</div>
		</dl>
	</div>
</section>
