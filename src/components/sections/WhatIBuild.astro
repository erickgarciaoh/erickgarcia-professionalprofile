---
import PipelineSteps from '../PipelineSteps.astro';
---

<section id="what-i-build" data-section-label="What I build" aria-labelledby="what-i-build-heading">
	<div class="wrap">
		<h2 id="what-i-build-heading" class="section-heading">What I build</h2>
		<p class="what-i-build-intro">
			From raw operational tables to decisions people can act on — this is the pipeline every
			project walks.
		</p>

		<PipelineSteps />
	</div>
</section>

<style>
	.what-i-build-intro {
		margin-top: var(--space-5);
		max-width: 60ch;
		font-size: 1.0625rem;
		color: var(--canvas-700);
		text-wrap: pretty;
	}
</style>
