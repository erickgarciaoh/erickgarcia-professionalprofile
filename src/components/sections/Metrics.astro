---
import Counter from '../Counter.astro';

const kpis = [
	{ to: 1_400_000, display: '1.4M+', format: 'compact' as const, suffix: '+', label: 'monthly interactions reported' },
	{ to: 6, display: '6', format: 'none' as const, suffix: '', label: 'enterprise accounts served simultaneously' },
	{ to: 90, display: '90%+', format: 'none' as const, suffix: '%+', label: 'stakeholder satisfaction' },
];
---

<section id="metrics" data-theme="dark" aria-labelledby="metrics-heading">
	<div class="wrap">
		<h2 id="metrics-heading" class="section-heading">Six years of production numbers</h2>
		<p class="metrics-bio lede-measure">
			Six-plus years building reporting systems for enterprise financial-services clients,
			inside high-volume, SLA-driven contact-center operations.
		</p>

		{
			/* Client-logo marquee (Capital One, Visa, CitiGroup) is a documented alternative
			   per §2.6 of the blueprint — NOT built here. Do not build it without Erick
			   explicitly confirming NDA/permission status for naming financial clients and
			   using their logos. */
		}

		<dl class="kpi-list" data-reveal-group>
			{
				kpis.map((kpi) => (
					<div class="kpi-row" data-reveal-item>
						<dt class="kpi-label">{kpi.label}</dt>
						<dd class="kpi-figure">
							<Counter to={kpi.to} display={kpi.display} format={kpi.format} suffix={kpi.suffix} />
						</dd>
					</div>
				))
			}
		</dl>
	</div>
</section>

<style>
	section#metrics {
		background: var(--ink-950);
		color: var(--text-primary);
		padding-bottom: clamp(var(--space-8), 4vw, var(--space-12));
	}

	.metrics-bio {
		margin-top: var(--space-6);
		font-size: 1.0625rem;
		color: var(--text-secondary);
		text-wrap: pretty;
	}

	.kpi-list {
		margin: clamp(var(--space-10), 5vw, var(--space-16)) 0 0;
		border-top: 1px solid var(--border-default);
	}

	.kpi-row {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: baseline;
		gap: var(--space-6);
		padding-block: var(--space-6);
		border-bottom: 1px solid var(--border-default);
	}

	.kpi-label {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--canvas-500);
	}

	.kpi-figure {
		margin: 0;
		font-family: var(--font-ui);
		font-weight: 200;
		font-size: clamp(2.25rem, 5vw, 3.25rem);
		color: var(--text-primary);
		white-space: nowrap;
	}

	@media (max-width: 30rem) {
		.kpi-row {
			grid-template-columns: 1fr;
			gap: var(--space-2);
		}
	}
</style>
