---
import { Image, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
	projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;

// Server-resolved initial active project (§2.6): no JS needed for the panel to
// show project 1. work-panel.ts (P4-03) switches it on hover/focus.
const active = projects[0];

// Per-project panel payload, pre-resolved at build time (§2.6). getImage gives a
// single real URL (not the <Image> responsive srcset, whose srcset would clobber
// img.src on swap) sized for the large sticky panel, plus the meta each row hands
// to work-panel.ts via data-* attributes. Same build-time resolution pattern the
// retired cursor preview used, now feeding the panel instead of a floating figure.
const panels = await Promise.all(
	projects.map(async (project) => {
		const cover = await getImage({ src: project.data.cover, width: 1200 });
		return {
			cover: cover.src,
			alt: project.data.coverAlt,
			dataset: project.data.datasetSize ?? '',
			stack: project.data.stack.join(' · '),
			live: project.data.liveUrl,
			title: project.data.title,
		};
	}),
);
---

<section id="projects" data-theme="dark" data-section-label="Work" aria-labelledby="projects-heading">
	<div class="wrap">
		<header class="projects-head">
			<h2 id="projects-heading" class="section-heading">Projects</h2>
			<p class="projects-intro">
				Each one ships as a live data-story with its SQL and repo in the open — the
				work is the argument.
			</p>
		</header>

		<div class="work-layout">
			<ol class="project-list">
				{
					projects.map((project, index) => (
						<li
							class:list={['project-row', { 'is-active': index === 0 }]}
							style={`--i:${index}`}
							data-cover={panels[index].cover}
							data-cover-alt={panels[index].alt}
							data-dataset={panels[index].dataset}
							data-stack={panels[index].stack}
							data-live={panels[index].live}
							data-title={panels[index].title}
						>
							<span class="row-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
							<a
								class="row-media"
								href={project.data.liveUrl}
								aria-label={`Open the live data-story for ${project.data.title}`}
								tabindex="-1"
							>
								<Image
									src={project.data.cover}
									alt={project.data.coverAlt}
									widths={[240, 480]}
									sizes="(max-width: 60rem) 100vw, 22rem"
									loading="lazy"
								/>
							</a>
							<div class="row-body">
								<h3 class="row-title">
									<a href={project.data.liveUrl}>{project.data.title}</a>
								</h3>
								<p class="row-blurb">{project.data.blurb ?? project.data.summary}</p>
								<p class="project-summary row-summary">{project.data.summary}</p>
								<ul class="stack row-stack" aria-label="Stack">
									{project.data.stack.map((tool) => (
										<li>{tool}</li>
									))}
								</ul>
								<div class="project-links row-links">
									<a
										class="link-live"
										href={project.data.liveUrl}
										aria-label={`Open the live data-story for ${project.data.title}`}
									>
										Live data-story <span aria-hidden="true">↗</span>
									</a>
									<a
										class="link-repo"
										href={project.data.repoUrl}
										aria-label={`View the repository for ${project.data.title}`}
									>
										Repository <span aria-hidden="true">↗</span>
									</a>
								</div>
								<a
									class="link-repo row-repo"
									href={project.data.repoUrl}
									aria-label={`View the repository for ${project.data.title}`}
								>
									Repository <span aria-hidden="true">↗</span>
								</a>
							</div>
						</li>
					))
				}
			</ol>

			<figure class="work-panel">
				<div class="work-panel-media">
					<img src={panels[0].cover} alt={active.data.coverAlt} loading="lazy" decoding="async" />
				</div>
				<figcaption>
					<dl class="panel-meta">
						{
							active.data.datasetSize && (
								<div class="panel-meta-row panel-meta-dataset">
									<dt>Dataset</dt>
									<dd>{active.data.datasetSize}</dd>
								</div>
							)
						}
						<div class="panel-meta-row panel-meta-stack">
							<dt>Stack</dt>
							<dd>{active.data.stack.join(' · ')}</dd>
						</div>
					</dl>
					<a
						class="link-live panel-live"
						href={active.data.liveUrl}
						aria-label={`Open the live data-story for ${active.data.title}`}
					>
						Live data-story <span aria-hidden="true">↗</span>
					</a>
				</figcaption>
			</figure>
		</div>
	</div>
</section>
