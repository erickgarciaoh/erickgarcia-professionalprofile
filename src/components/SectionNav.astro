---
interface Section {
	id: string;
	label: string;
}

interface Props {
	sections: Section[];
}

const { sections } = Astro.props;
---

<nav class="section-nav" aria-label="Section progress">
	<ol>
		{
			sections.map((section) => (
				<li>
					<a href={`#${section.id}`} data-section-dot data-target={section.id}>
						<span class="dot" aria-hidden="true" />
						<span class="dot-label">{section.label}</span>
					</a>
				</li>
			))
		}
	</ol>
</nav>

<style>
	.section-nav {
		position: fixed;
		top: 50%;
		right: var(--space-6);
		transform: translateY(-50%);
		z-index: 50;
	}

	.section-nav ol {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.section-nav a {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		text-decoration: none;
	}

	.dot {
		flex-shrink: 0;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--canvas-400);
		transition:
			background-color var(--motion-base),
			transform var(--motion-base);
	}

	.dot-label {
		position: absolute;
		right: calc(100% + var(--space-2));
		top: 50%;
		translate: 0 -50%;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		white-space: nowrap;
		/* canvas-700, not text-secondary: at 11px this label needs AA 4.5:1 on the
		   light canvas — secondary is 4.28, canvas-700 is 7.35 (P6-04 A11Y-3). */
		color: var(--canvas-700);
		opacity: 0;
		transform: translateX(4px);
		transition:
			opacity var(--motion-base),
			transform var(--motion-base),
			color var(--motion-base);
	}

	.section-nav a:hover .dot-label,
	.section-nav a:focus-visible .dot-label,
	.section-nav a[aria-current='true'] .dot-label {
		opacity: 1;
		transform: translateX(0);
	}

	.section-nav a[aria-current='true'] .dot {
		background: var(--canvas-700);
		transform: scale(1.3);
	}

	/* Theme-aware overlay (P6-04 A11Y-3): section-nav.ts adds .is-over-dark while a
	   dark section (#projects/#metrics/#toolkit) is active, so the label + dots swap
	   to the light-on-dark palette — canvas-100 label is 15.6:1 on the dark band and
	   the dots stay legible, where the fixed light-world colours vanished. */
	.section-nav.is-over-dark .dot {
		background: var(--canvas-600);
	}

	.section-nav.is-over-dark a[aria-current='true'] .dot {
		background: var(--canvas-100);
	}

	.section-nav.is-over-dark .dot-label {
		color: var(--canvas-100);
	}

	@media (max-width: 60rem) {
		.section-nav {
			display: none;
		}
	}
</style>
