---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Hero from '../components/sections/Hero.astro';
import WhatIDo from '../components/sections/WhatIDo.astro';
import WhatIBuild from '../components/sections/WhatIBuild.astro';
import PromiseSection from '../components/sections/Promise.astro';
import SelectedWork from '../components/sections/SelectedWork.astro';
import Metrics from '../components/sections/Metrics.astro';
import Toolkit from '../components/sections/Toolkit.astro';
import Contact from '../components/sections/Contact.astro';
import SectionNav from '../components/SectionNav.astro';
import '../styles/page.css';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const sectionNavItems = [
	{ id: 'hero', label: 'Home' },
	{ id: 'what-i-do', label: 'What I do' },
	{ id: 'what-i-build', label: 'What I build' },
	{ id: 'promise', label: 'Promise' },
	{ id: 'projects', label: 'Work' },
	{ id: 'metrics', label: 'Metrics' },
	{ id: 'toolkit', label: 'Toolkit' },
	{ id: 'contact', label: 'Contact' },
];
---

<Layout
	title="Erick García — Senior Data Analyst / BI"
	description="Senior Data Analyst / BI. SQL Server, Power BI, and AI-augmented analytics — portfolio and contact."
>
	<a class="skip-link" href="#main">Skip to content</a>

	<header class="site-header">
		<div class="wrap">
			<a class="site-mark" href="#hero" aria-label="Erick García — home">EG</a>
			<nav class="primary-nav" aria-label="Primary">
				<a href="#what-i-do">What I do</a>
				<a href="#projects">Work</a>
				<a href="#contact">Contact</a>
			</nav>
		</div>
	</header>

	<main id="main">
		<Hero />
		<WhatIDo />
		<WhatIBuild />
		<PromiseSection />
		<SelectedWork projects={projects} />
		<Metrics />
		<Toolkit />
		<Contact />
	</main>

	<SectionNav sections={sectionNavItems} />

	<footer class="site-footer">
		<div class="wrap">
			<p>&copy; {new Date().getFullYear()} Erick García. Built with Astro.</p>
		</div>
	</footer>
</Layout>

<script>
	import '../scripts/motion/index';
</script>

<script>
	// Phase 4 — dark-window threshold. Reveal the projects section once, when it
	// scrolls into view. Enhancement only: without this (or without IO support)
	// the section is already fully visible; the from-state lives behind
	// [data-reveal="js"], set on <html> in Layout.astro.
	const projects = document.getElementById('projects');

	if (projects) {
		const reveal = () => projects.classList.add('is-revealed');

		if (!('IntersectionObserver' in window)) {
			reveal();
		} else {
			const io = new IntersectionObserver(
				(entries, obs) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							reveal();
							obs.disconnect();
						}
					}
				},
				{ threshold: 0.15, rootMargin: '0px 0px -8% 0px' },
			);
			io.observe(projects);
		}
	}

	// Sticky header — border-on-scroll, so the header only reads as "docked"
	// once there's content behind it to separate from.
	const header = document.querySelector('.site-header');

	if (header) {
		const setScrolled = () => header.classList.toggle('is-scrolled', window.scrollY > 4);
		setScrolled();
		window.addEventListener('scroll', setScrolled, { passive: true });
	}
</script>
